    <UserSecretsId>31d18b37-cf6b-474a-ad19-f2408c651e81</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.0" />
